@page "/status"

@if (loading)
{
    <Loading/>
}
else
{
    <MudTable @ref="table"
              ServerData="LoadListAsync"
              Dense="true"
              Hover="true"
              Striped="true"
              FixedHeader="true"
              FixedFooter="true">
        <ToolBarContent>
            <div class="d-flex justify-content-between">
                <MudText Typo="Typo.h6" Class="me-4"> @Localizer["Iva"]</MudText>

                <MudButton Variant="Variant.Outlined"
                           EndIcon="@Icons.Material.Filled.Add"
                           Color="Color.Info" OnClick="@(() => ShowModalAsync())">
                    @Localizer["New"]
                </MudButton>

            </div>
            <MudSpacer />
            <FilterComponent ApplyFilter="SetFilterValue" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh> <MudTableSortLabel T="Statu" SortLabel="Name">@Localizer["Name"]</MudTableSortLabel></MudTh>
            <MudTh> <MudTableSortLabel T="Statu" SortLabel="Worth">@Localizer["Level"]</MudTableSortLabel></MudTh>
            <MudTh Class="text-center">@Localizer["Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd >@context.Name</MudTd>
            <MudTd>@context.Level</MudTd>
            <MudTd Class="text-center">
                <MudTooltip Text="@Localizer["Edit"]">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="delete" OnClick="@(() => ShowModalAsync(@context.Id, true))" Color="Color.Warning" />
                </MudTooltip>
                <MudTooltip Text="@Localizer["Delete"]">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="delete" OnClick="@(() => DeleteAsync(@context))" Color="Color.Error" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>@Localizer["NoRecords"]</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager RowsPerPageString=@Localizer["RecordsNumber"]
                           PageSizeOptions="pageSizeOptions"
                           AllItemsText=@Localizer["All"]
                           InfoFormat="@infoFormat" />
        </PagerContent>
    </MudTable>
}