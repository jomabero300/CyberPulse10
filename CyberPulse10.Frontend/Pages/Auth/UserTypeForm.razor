<NavigationLock OnBeforeInternalNavigation="OnBeforeInternalNavigation" />

<EditForm EditContext="editContext" OnValidSubmit="OnValidSubmit">

	<DataAnnotationsValidator />

	<MudGrid Style="margin-bottom:1em">
		<MudItem xs="12">
			<MudTextField Label="@Localizer["Name"]"
						  Disabled="true"
						  Value="@user.FullName"
						  For="@(() => user.FullName)"
						  class="mb-3" />

			<MudSelect T="UserType" @bind-Value="@user.UserType" Label="Tipo" Style="margin-bottom:2em">
				@foreach (UserType tipo in Enum.GetValues(typeof(UserType)))
				{
					<MudSelectItem Value="@tipo">@tipo.GetDisplayName()</MudSelectItem>
				}
			</MudSelect>
		</MudItem>
	</MudGrid>

	<MudButton Variant="Variant.Outlined"
			   StartIcon="@Icons.Material.Filled.ArrowBack"
			   Color="Color.Error"
			   OnClick="ReturnAction">
		@Localizer["Return"]
	</MudButton>

	<MudButton Variant="Variant.Outlined"
			   StartIcon="@Icons.Material.Filled.Check"
			   Color="Color.Primary"
			   ButtonType="ButtonType.Submit">
		@Localizer["SaveChanges"]
	</MudButton> 
</EditForm>